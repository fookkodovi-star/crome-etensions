{
  "manifest_version": 3,
  "name": "Sora 2 Prompt Wizard",
  "description": "Генератор оригинальных промтов для Sora 2 с оценкой и отправкой.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Sora 2 Prompt Wizard",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://router.huggingface.co/*",
    "https://sora.chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
